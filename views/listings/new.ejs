
<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <br><br>
  <h1>Add New Listing</h1>

<form method="POST" action="/listings" enctype="multipart/form-data" novalidate class="needs-validation">

<div class="mt-3 mb-3">
<label class="form-label">Title</label>
<input type="text" name="listing[title]" class="form-control" required>
</div>

<div class="mb-3">
<label class="form-label">Description</label>
<textarea name="listing[description]" class="form-control" required></textarea>
</div>

<div class="mb-3">
<label class="form-label">Upload Listing Image</label>
<input type="file" name="listing[image]" class="form-control" required>
</div>

<div class="row">

<div class="mb-3 col-md-4">
<label class="form-label">Price</label>
<input name="listing[price]" class="form-control" placeholder="2500" required>
</div>

<div class="mb-3 col-md-8">
<label class="form-label">Country</label>
<input type="text" name="listing[country]" class="form-control" placeholder="India" required>
</div>

</div>

<div class="mb-3">
<label class="form-label">Location</label>
<input type="text" name="listing[location]" class="form-control" placeholder="Mysuru, Karnataka" required>
</div>

<button class="btn btn-dark add-btn mt-4 mb-5">ADD</button>

</form>
  </div>
</div>


